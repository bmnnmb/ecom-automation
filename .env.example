# ============================================
# Hermes 多平台电商自动化系统 - 环境变量配置
# ============================================
# 使用方法: cp .env.example .env && vim .env
# 所有变量在 docker-compose.yml 中都有默认值，按需修改
# ============================================

# ─── 数据库 ───
DB_PASSWORD=ecom2024

# ─── 抖店开放平台 ───
DOUYIN_APP_KEY=
DOUYIN_APP_SECRET=

# ─── 快手开放平台 ───
KUAISHOU_APP_KEY=
KUAISHOU_APP_SECRET=

# ─── 拼多多开放平台 ───
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_ACCESS_TOKEN=

# ─── 闲鱼配置（浏览器自动化） ───
XIANYU_COOKIE=

# ─── n8n 工作流 ───
N8N_USER=admin
N8N_PASSWORD=n8n2024

# ─── AI 配置（Hermes 控制中心 & RAG 使用） ───
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── 通知配置 ───
WECHAT_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 日志与环境 ───
LOG_LEVEL=INFO
ENV=production
